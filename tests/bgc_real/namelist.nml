!================================================================================
!                             SIMULATION TITLE
!================================================================================
! Previously set in `roms.in`
!================================================================================
&SIMULATION_NAME_SETTINGS                                      !roms_read_write.F
!------------------------
output_root_name = "roms"
title = "roms_run"
/

!================================================================================
!                               TIME STEPPING
!================================================================================
! Previously set in `roms.in`
!================================================================================
&TIME_STEPPING 							       !scalars.F
!-------------
ntimes = 10
dt = 20
ndtfast = 30
ninfo = 1
/

!================================================================================
!                              GRID AND INPUT FILES
!================================================================================
! Previously set in `roms.in`
!================================================================================
&GRID_SETTINGS	                                                    !dimensions.F
!-------------
grdname = "input_data/example_input_grid.nc"
/

&S_COORD                                                                !scoord.F
!-------
theta_s = 6.D0
theta_b = 6.D0
hc = 25.0D0
/

&INITIAL_CONDITIONS                                            !roms_read_write.F
!------------------
ininame = "input_data/example_input_bgc_initial_conditions.nc"
nrrec = 1
/

&FORCING_FILES                                                 !roms_read_write.F
!-------------
frcfile =
'input_data/example_input_bgc_surface_forcing_clim.nc',
'input_data/example_input_bgc_boundary_forcing_clim.nc',
'input_data/example_input_boundary_forcing.nc',
'input_data/example_input_surface_forcing.nc',
'input_data/example_input_tides.nc'
/

!================================================================================
!                            RIVER INPUT PARAMETERS
!================================================================================
! Previously set in `river_frc.opt`
!================================================================================
&RIVER_FRC_SETTINGS                                                  !river_frc.F
nriv = 0
/

!================================================================================
!                            TIDAL FORCING PARAMETERS
!================================================================================
! Previously set in `tides.opt`
! Requires TIDES cppkey
!================================================================================
&TIDES_SETTINGS                                                          !tides.F
ntides = 10
/

!================================================================================
!                        BASIC MODEL NETCDF OUTPUT CONTROLS
!================================================================================
&BASIC_OUTPUT_SETTINGS                                            !basic_output.F
!---------------------
! Previously set in `ocean_vars.opt`
!---------------------
output_period_rst = 2000
nrpf_rst = 10
output_period_his = 100
nrpf_his = 20
output_period_avg = 100
nrpf_avg = 20
/

&FRC_OUTPUT_SETTINGS                                                !frc_output.F
!-------------------
! Previously set in `frc_output.opt`
!-------------------
output_period = 0.
nrpf = 0
/

!================================================================================
!                               NESTED SIMULATIONS
!================================================================================
&EXTRACT_DATA_SETTINGS                                            !extract_data.F
!---------------------
! Previously set in `extract_data.opt`,
! require EXTRACT_DATA cppkey
!---------------------
extract_period = 0.0
extract_file = ""
nrpf_extract = 0
N_chd = 0
theta_s_chd = 0
theta_b_chd = 0
hc_chd = 0
/

&SPONGE_TUNE_SETTINGS                                              !sponge_tune.F
!--------------------
! Previously set in `sponge_tune.opt`
! Require SPONGE_TUNE cppkey
!--------------------
sp_timscale = 0
nrpf = 0
output_period = 0
/

&CALC_PFLX_SETTINGS                                              !calc_pflx_mod.F
!---------------------
! Previously set in `calc_pflx.opt`
!---------------------
timescale = 0
/

!================================================================================
!                                OUTPUT ON Z LEVELS
!================================================================================
! Previously set in `zslice_output.opt`
!================================================================================
&ZSLICE_SETTINGS                                                 !zslice_output.F
output_period = 0
nrpf = 0
ndep = 0
vecdep = -0,0
nt_z = 0
trc2zsc = 0, 0
/


!================================================================================
!                                BIOGEOCHEMISTRY
!================================================================================
! Requires MARBL or BIOLOGY_BEC2 cpp keys
!================================================================================
&BGC_SETTINGS                                                !bgc_shared_vars.opt
!------------
! Previously set in `bgc.opt`
!------------
output_period_his = 100
nrpf_his = 10
output_period_avg = 100
nrpf_avg = 10
output_period_his_dia = 100
nrpf_his_dia = 10
output_period_avg_dia = 100
nrpf_avg_dia = 10
/

&MARBL_BIOGEOCHEMISTRY_SETTINGS                                  !marbl_driver.F
!------------------------------
! Previously set in `roms.in`
!------------------------------
marbl_namelist_fname = "marbl_in"
marbl_tracer_list_fname = "marbl_tracer_output_list"
marbl_diag_list_fname = "marbl_diagnostics_output_list"
/

!================================================================================
!                    CARBON DIOXIDE REMOVAL FORCING & OUTPUT
!================================================================================
&CDR_FRC_SETTINGS                                                      !cdr_frc.F
!----------------
! Previously set in `cdr_frc.opt`
! Requires CDR_FORCING cppkey
!----------------
cdr_file = "input_data/cdr_forcing_dp.nc"  ! NetCDF forcing file
ncdr_parm = 0  !! number of discrete CDR releases; only used with PARAMETERIZED or 3D FORCING
nz_chd = 50
/

&CDR_OUTPUT_SETTINGS                                               !cdr_output.F
!-------------------
! Previously set in `cdr_output.opt`
!-------------------
output_period = 0
nrpf = 0
/

&UPSCALE_SETTINGS                                              !upscale_output.F
!----------------
! Previously set in `upscale_output.opt`
! Requires UPSCALING cppkey
!----------------
nrpf_uscl = 0
output_period_uscl = 0
/

!================================================================================
!                         OTHER MODEL PHYSICS SETTINGS
!================================================================================
! Previously set in `roms.in`
!================================================================================
&LIN_RHO_EOS_SETTINGS                                                  !scalars.F
!--------------------
Tcoef = 0.
T0 = 0.
Scoef = 0.
S0 = 0.
/

&RHO0_SETTINGS                                                         !scalars.F
!-------------
! Requires SOLVE3D cppkey
!-------------
rho0 = 1027.5
/

&GAMMA2_SETTINGS                                                       !scalars.F
!---------------
gamma2 = 1.0
/

&TRACER_DIFF2                                                          !scalars.F
!------------
! Requires SOLVE3D and TS_DIF2 cppkeys
!------------
tnu=0.0
/

&BOTTOM_DRAG_SETTINGS                                                  !scalars.F
!--------------------
rdrg = 0.e-4
rdrg2 = 1.0e-3
zob = 1.e-2
/

&VERTICAL_MIXING_SETTINGS                                              !scalars.F
!------------------------
!Requires SOLVE3D cppkey (and MY_BAK_MIXING cppkey for akq_bak)
!------------------------
akv_bak = 0.0
akt_bak = 0.0
!akq_bak = 0. !(if MY_BAK_MIXING)
/

&LATERAL_VISC_SETTINGS                                                 !scalars.F
!---------------------
! Requires UV_VIS2 cppkey
!---------------------
visc2 = 0.
/

&UBIND_SETTINGS                                                        !scalars.F
!--------------
!Requires T_FRC_BRY, M2_FRC_BRY, Z_FRC_BRY, M3_FRC_BRY, or M2NUDGING cppkeys
!--------------
ubind = 0.1
/

&V_SPONGE_SETTINGS                                                     !scalars.F
!-----------------
!Requires SPONGE cppkey
!-----------------
v_sponge = 1.0
/

!================================================================================
!                               SURFACE RESTORING
!================================================================================
! Previously set in `roms.in`
!================================================================================
&SSS_CORRECTION                                                       !surf_flx.F
!--------------
! Requires SFLX_CORR and SALINITY cppkeys
!--------------
dSSSdt = 0.
/

&SST_CORRECTION                                                       !surf_flx.F
!--------------
! Requires QCORRECTION cppkey
!--------------
dSSTdt = 0.
/

!================================================================================
!                           OTHER OUTPUT CONTROLS
!================================================================================
&DIAGNOSTICS_SETTINGS
!--------------------
! Previously set in `diagnostics.opt`
! Requires DIAGNOSTICS cppkey
!--------------------
output_period = 0.
nrpf = 0
/

&RANDOM_OUTPUT_SETTINGS
!----------------------
! Previously set in `random.opt`
!----------------------
output_period = 0
nrpf=0
/

&SURF_FLX_SETTINGS
!-----------------
! Previously set in `surf_flx.opt`
!-----------------
output_period = 0
nrpf = 0
/

!================================================================================
!                            PIPE INPUT PARAMETERS
!================================================================================
! Formerly in `pipe_frc.opt`
!================================================================================
&PIPE_FRC_SETTINGS
npip = 0
/

!================================================================================
!                           LAGRANGIAN PARTICLES
!================================================================================
! Formerly in `particles.opt`
!================================================================================
&PARTICLES_SETTINGS
np=0
extra_space_fac = 0.
exchange_facx = 0.
exchange_facy = 0.
exchange_facc = 0.
output_period = 0
nrpf = 0
ppm3 = 0.
pmin = 0
/



