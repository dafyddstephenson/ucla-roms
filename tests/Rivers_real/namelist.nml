!================================================================================
!                             SIMULATION TITLE
!================================================================================
! Previously set in `roms.in`
!================================================================================
&SIMULATION_NAME_SETTINGS                                      !roms_read_write.F
!------------------------
output_root_name = "roms"
title = "roms_run"
/

!================================================================================
!                               TIME STEPPING
!================================================================================
! Previously set in `roms.in`
!================================================================================
&TIME_STEPPING 							       !scalars.F
!-------------
ntimes = 20
dt = 40
ndtfast = 30
ninfo = 1
/

!================================================================================
!                              GRID AND INPUT FILES
!================================================================================
&GRID_SETTINGS	                                                    !dimensions.F
!---------------------------
! Previously set in `roms.in`
!---------------------------
grdname = "input_data/example_input_grid.nc"
/

&S_COORD                                                                !scoord.F
!---------------------------
! Previously set in `roms.in`
!---------------------------
theta_s = 6.D0
theta_b = 6.D0
hc = 25.0D0
/

&PARAM_SETTINGS
!------------------------------
! Previously set in `param.opt`
!------------------------------
NP_XI = 3
NP_ETA = 2
NSUB_X = 1
NSUB_E = 1
LLm = 199
MMm = 99
N = 50
nt_passive = 0
ntrc_bio = 0
/


&INITIAL_CONDITIONS                                            !roms_read_write.F
!---------------------------
! Previously set in `roms.in`
!---------------------------
ininame = "input_data/example_input_bgc_initial_conditions.nc"
nrrec = 1
/

&FORCING_FILES                                                 !roms_read_write.F
!---------------------------
! Previously set in `roms.in`
!---------------------------
frcfile =
'input_data/example_input_boundary_forcing.nc',
'input_data/example_input_surface_flux_forcing.nc',
'input_data/example_input_river_forcing.nc'
/

!================================================================================
!                             FORCING SETTINGS
!================================================================================
&BULK_FRC_SETTINGS
interp_bulk_frc = .true.
check_bulk_frc_units = .false.
/

&FLUX_FRC_SETTINGS
interp_flux_frc = .true.
/

!================================================================================
!                            RIVER INPUT PARAMETERS
!================================================================================
! Previously set in `river_frc.opt`
!================================================================================
&RIVER_FRC_SETTINGS                                                  !river_frc.F
river_source = .true. ! on/off switch for river input
river_analytical = .false. ! Specify inputs analytically
nriv = 1
/

!================================================================================
!                            TIDAL FORCING PARAMETERS
!================================================================================
! Previously set in `tides.opt`
! Requires TIDES cppkey
!================================================================================
&TIDES_SETTINGS                                                          !tides.F
bry_tides=.false. ! Barotropic (TPXO) tides at the boundary
pot_tides=.false. ! Surface tidal potential
ana_tides=.false. ! Specify tides analytically
ntides = 0
/

!================================================================================
!                        BASIC MODEL NETCDF OUTPUT CONTROLS
!================================================================================
&BASIC_OUTPUT_SETTINGS                                            !basic_output.F
!---------------------
! Previously set in `ocean_vars.opt`
!---------------------
wrt_file_his = .true.   ! Write output as snapshots
wrt_file_avg = .false.  ! Write output as averages
wrt_file_rst = .false.  ! Write model restart files
monthly_restarts = .false.   ! This overrides output_period
wrt_Z =.true. ! Include `zeta`
wrt_Ub=.true. ! Include `ubar`
wrt_Vb=.true.! Include `vbar`
wrt_U=.true.! Include `u`
wrt_V=.true.! Include `v`
wrt_R=.true.! Include `rho`
wrt_O=.true.! Include `omega`
wrt_W=.true.! Include `w`
wrt_Akv=.true.! Include `Akv`
wrt_Akt=.true.! Include `Akt`
wrt_Aks=.true.! Include `Aks`
wrt_Hbls=.true.! Include `hbls`
wrt_Hbbl=.true.! Include `hbbl`

  ! Control output variables (averages file):
wrt_avg_Z =.true.! Include `zeta`
wrt_avg_Ub=.true. ! Inlucde `ubar`
wrt_avg_Vb=.true.! Include `vbar`
wrt_avg_U=.true.! Include `u`
wrt_avg_V=.true.! Include `v`
wrt_avg_R=.true.! Include `rho`
wrt_avg_O=.true.! Include `omega`
wrt_avg_W=.true.! Include `w`
wrt_avg_Akv=.true.! Include `Akv`
wrt_avg_Akt=.true.! Include `Akt`
wrt_avg_Aks=.true. ! Include `Aks`
wrt_avg_Hbls=.true.! Include `hbls`
wrt_avg_Hbbl=.true.! Include `hbbl`
output_period_rst = 2000
nrpf_rst = 10
output_period_his = 800
nrpf_his = 20
output_period_avg = 100
nrpf_avg = 20
/

&TS_OUTPUT_SETTINGS
wrt_temp = .false.
wrt_salt = .false.
wrt_temp_dia = .false.
wrt_salt_dia = .false.
/

&FRC_OUTPUT_SETTINGS                                                !frc_output.F
!-------------------
! Previously set in `frc_output.opt`
!-------------------
wrt_frc = .false.    ! forcing output on/off switch
wrt_frc_avg = .false.! averages(T) or snapshots (F)
output_period = 0.
nrpf = 0
/

!================================================================================
!                               NESTED SIMULATIONS
!================================================================================
&EXTRACT_DATA_SETTINGS                                            !extract_data.F
!---------------------
! Previously set in `extract_data.opt`,
! require EXTRACT_DATA cppkey
!---------------------
do_extract = .false. ! on/off switch for generation
extract_period = 0
extract_file = ""
nrpf_extract = 0
N_chd = 0
theta_s_chd = 0
theta_b_chd = 0
hc_chd = 0
/

&SPONGE_TUNE_SETTINGS                                              !sponge_tune.F
!--------------------
! Previously set in `sponge_tune.opt`
! Require SPONGE_TUNE cppkey
!--------------------
ub_tune = .false. ! on/off switch for sponge tuning
wrt_sponge=.false. ! output sponge to file
spn_avg = .false.  ! write as averages (T) or snapshots (F)
sp_timscale = 0
nrpf = 0
output_period = 0
/

&CALC_PFLX_SETTINGS                                              !calc_pflx_mod.F
!---------------------
! Previously set in `calc_pflx.opt`
!---------------------
calc_pflx     = .false.   ! Baroclinic pressure fluxes
timescale = 0
/

!================================================================================
!                                OUTPUT ON Z LEVELS
!================================================================================
! Previously set in `zslice_output.opt`
!================================================================================
&ZSLICE_SETTINGS                                                 !zslice_output.F
do_zslice  = .false. ! on/off switch for sigma-z conversion
zslice_avg = .false. ! output averages (T) or snapshots (T)
wrt_T_zsl  = .false.  ! Include tracers
wrt_U_zsl  = .false.   ! Include u-velocity
wrt_V_zsl  = .false.   ! Include v-velocity
output_period = 0
nrpf = 0
ndep = 0
vecdep = -0,0
nt_z = 0
trc2zsc = 0, 0
/


!================================================================================
!                                BIOGEOCHEMISTRY
!================================================================================
! Requires MARBL or BIOLOGY_BEC2 cpp keys
!================================================================================
&BGC_SETTINGS                                                !bgc_shared_vars.opt
!------------
! Previously set in `bgc.opt`
!------------
output_period_his = 100
nrpf_his = 10
output_period_avg = 100
nrpf_avg = 10
output_period_his_dia = 100
nrpf_his_dia = 10
output_period_avg_dia = 100
nrpf_avg_dia = 10
wrt_bgc_his = .false.     ! t/f to write tracer history file
wrt_bgc_avg = .false.     ! t/f to write tracer averages file
wrt_bgc_dia_his = .false. ! t/f to write diagnostic history file
wrt_bgc_dia_avg = .false. ! t/f to write diagnostic averages file
interp_bgc_frc = .true.   ! interpolate forcing from coarser grid
/

&MARBL_BIOGEOCHEMISTRY_SETTINGS                                  !marbl_driver.F
!------------------------------
! Previously set in `roms.in`
!------------------------------
marbl_config_file = ""
marbl_tracers_to_write = ""
marbl_diagnostics_to_write = ""
/

!================================================================================
!                    CARBON DIOXIDE REMOVAL FORCING & OUTPUT
!================================================================================
&CDR_FRC_SETTINGS                                                      !cdr_frc.F
!----------------
! Previously set in `cdr_frc.opt`
! Requires CDR_FORCING cppkey
!----------------
cdr_source  = .false.  ! on/off switch for CDR forcing
forcing_depth_profiles = .false. ! T if this file contains depth profiles
forcing_3d             = .true. ! T if this file contains 3d forcing
forcing_parameterized  = .false. ! T if forcing with idealized Gaussian profiles
! Linear time interpolation between records (T), or step changes (F)
time_interpolation = .false.
! Prevent errors by relocating single-point CDR forcing locations on land to water
relocate_to_wet_pts = .false.
cdr_file = "cdr_forcing_3d.nc"  ! NetCDF forcing file
ncdr_parm = 1  !! number of discrete CDR releases; only used with PARAMETERIZED or 3D FORCING
nz_chd = 50
/

&CDR_OUTPUT_SETTINGS                                               !cdr_output.F
!-------------------
! Previously set in `cdr_output.opt`
!-------------------
do_cdr_output   = .false. ! on/off switch for CDR-specific output
wrt_cdr_avg   = .false. ! Write averages (T) or snapshots(F)
! Write averages over calendar months:
cdr_monthly_averages = .false.
output_period = 0
nrpf = 0
/

&UPSCALE_SETTINGS                                              !upscale_output.F
!----------------
! Previously set in `upscale_output.opt`
! Requires UPSCALING cppkey
!----------------
do_upscale = .false.
nrpf_uscl = 0
output_period_uscl = 0
/

!================================================================================
!                         OTHER MODEL PHYSICS SETTINGS
!================================================================================
! Previously set in `roms.in`
!================================================================================
&LIN_RHO_EOS_SETTINGS                                                  !scalars.F
!--------------------
Tcoef = 0.
T0 = 0.
Scoef = 0.
S0 = 0.
/

&RHO0_SETTINGS                                                         !scalars.F
!-------------
! Requires SOLVE3D cppkey
!-------------
rho0 = 1027.5
/

&GAMMA2_SETTINGS                                                       !scalars.F
!---------------
gamma2 = 1.0
/

&TRACER_DIFF2                                                          !scalars.F
!------------
! Requires SOLVE3D and TS_DIF2 cppkeys
!------------
tnu=0.0 0.0
/

&BOTTOM_DRAG_SETTINGS                                                  !scalars.F
!--------------------
rdrg = 0.e-4
rdrg2 = 1.0e-3
zob = 1.e-2
/

&VERTICAL_MIXING_SETTINGS                                              !scalars.F
!------------------------
!Requires SOLVE3D cppkey (and MY_BAK_MIXING cppkey for akq_bak)
!------------------------
akv_bak = 0.0
akt_bak = 0.0 0.0
!akq_bak = 0. !(if MY_BAK_MIXING)
/

&LATERAL_VISC_SETTINGS                                                 !scalars.F
!---------------------
! Requires UV_VIS2 cppkey
!---------------------
visc2 = 0.
/

&UBIND_SETTINGS                                                        !scalars.F
!--------------
!Requires T_FRC_BRY, M2_FRC_BRY, Z_FRC_BRY, M3_FRC_BRY, or M2NUDGING cppkeys
!--------------
ubind = 0.1
/

&V_SPONGE_SETTINGS                                                     !scalars.F
!-----------------
!Requires SPONGE cppkey
!-----------------
v_sponge = 1.0
/

!================================================================================
!                               SURFACE RESTORING
!================================================================================
! Previously set in `roms.in`
!================================================================================
&SSS_CORRECTION                                                       !surf_flx.F
!--------------
! Requires SFLX_CORR and SALINITY cppkeys
!--------------
dSSSdt = 0.
/

&SST_CORRECTION                                                       !surf_flx.F
!--------------
! Requires QCORRECTION cppkey
!--------------
dSSTdt = 0.
/

!================================================================================
!                           OTHER OUTPUT CONTROLS
!================================================================================
&DIAGNOSTICS_SETTINGS
!--------------------
! Previously set in `diagnostics.opt`
! Requires DIAGNOSTICS cppkey
!--------------------
diag_avg      = .false.  ! averages (T) or snapshots (F)
diag_uv       = .false. ! Momentum diagnostics
diag_trc      = .false. ! Selected tracers diagnostics
output_period = 0.
nrpf = 0
/

&STDOUT_DIAG_SETTINGS
code_check_mode = .true.
/

&RANDOM_OUTPUT_SETTINGS
!----------------------
! Previously set in `random.opt`
!----------------------
do_random = .false. ! on/off switch for custom output
output_period = 0
nrpf=0
/

&SURF_FLX_SETTINGS
!-----------------
! Previously set in `surf_flx.opt`
!-----------------
wrt_smflx = .false. ! output surface momentum flux
wrt_stflx = .false. ! output surface tracer flux
wrt_swflx = .false. ! output surface water flux (P-E)
sflx_avg  = .false. ! write averaged sflx data
output_period = 0
nrpf = 0
/

!================================================================================
!                            PIPE INPUT PARAMETERS
!================================================================================
! Formerly in `pipe_frc.opt`
!================================================================================
&PIPE_FRC_SETTINGS
pipe_source  = .false. ! on/off switch for pipe input
p_analytical = .false. ! Specify inputs analytically
npip = 0
/

!================================================================================
!                           LAGRANGIAN PARTICLES
!================================================================================
! Formerly in `particles.opt`
!================================================================================
&PARTICLES_SETTINGS
floats = .false.
full_seed = .false.
np=0
extra_space_fac = 0.
exchange_facx = 0.
exchange_facy = 0.
exchange_facc = 0.
output_period = 0
nrpf = 0
ppm3 = 0.
pmin = 0
/

!================================================================================
!                            ERROR HANDLING
!================================================================================
! Previously set in `error_handling_mod.F90`
!================================================================================
&ERROR_HANDLING_SETTINGS
gather_errors_on_main_rank = .true.
/
