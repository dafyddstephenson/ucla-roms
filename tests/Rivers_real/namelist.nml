&RIVER_FRC_SETTINGS
nriv = 1
/

&PIPE_FRC_SETTINGS
npip = 1
/

&CDR_FRC_SETTINGS
cdr_file = "cdr_release.nc"  ! NetCDF forcing file
ncdr_parm = 1  !! number of discrete CDR releases; only used with PARAMETERIZED or 3D FORCING
nz_chd = 50
/

&BGC_SETTINGS
output_period_his = 100
nrpf_his = 10
output_period_avg = 100
nrpf_avg = 10
output_period_his_dia = 100
nrpf_his_dia = 10
output_period_avg_dia = 100
nrpf_avg_dia = 10
/

&CALC_PFLX_SETTINGS
timescale = 86400
/

&CDR_OUTPUT_SETTINGS
output_period = 3600
nrpf = 4
/

&EXTRACT_DATA_SETTINGS
extract_period = 1800.0
extract_file = "sample_edata.nc"
nrpf_extract = 48
N_chd = 90
theta_s_chd = 5.0
theta_b_chd = 2.0
hc_chd = 250.0
/

&FRC_OUTPUT_SETTINGS
output_period = 3600.
nrpf = 4
/

&BASIC_OUTPUT_SETTINGS
output_period_rst = 2000
nrpf_rst = 10
output_period_his = 800
nrpf_his = 20
output_period_avg = 100
nrpf_avg = 20
/

&PARTICLES_SETTINGS
np=50
extra_space_fac = 1.5
exchange_facx = 0.1
exchange_facy = 0.1
exchange_facc = 0.01
output_period = 400
nrpf = 100
ppm3 = 1e-6
pmin = 200
/

&RANDOM_OUTPUT_SETTINGS
output_period = 3600
nrpf=10
/
